# —— Required ——
# LLM API token (Anthropic-style gateway). LLM_API_KEY is accepted as an alias.
ANTHROPIC_AUTH_TOKEN=your-token-here
# Gateway base URL and model name — no built-in defaults, must be set.
LLM_BASE_URL=https://your-gateway.example.com
LLM_MODEL=your-model-name

# —— Optional (defaults shown) ——
# PORT=8787
# WORKSPACE_ROOT=./workspaces
# LLM_PROVIDER=anthropic
# LLM_MAX_TOKENS=8192
# LLM_THINKING_BUDGET=2048    # 0 disables extended thinking
# MAX_STEP=10

# Execution environment: local | docker | opensandbox
# RUNTIME=local
# DOCKER_IMAGE=tinyhands-sandbox:latest
# OPENSANDBOX_SERVER_URL=http://localhost:8080
# OPENSANDBOX_API_KEY=
# OPENSANDBOX_IMAGE=opensandbox/code-interpreter:v1.1.0
