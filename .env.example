# —— Required ——
# Provider and model share one LiteLLM/OpenHands-style identifier.
LLM_MODEL=anthropic/your-model-name
LLM_API_KEY=your-token-here

# —— Optional (defaults shown) ——
# PORT=8787
# TINYHANDS_HOME=                  # override home dir; workspace → $TINYHANDS_HOME/workspace. default: ~ → ~/workspace. dev/test only.
# LLM_BASE_URL=                    # custom/private gateway; omitted → official provider endpoint
# OPENAI_API_KEY=                  # compatibility alias when LLM_MODEL=openai/...
# ANTHROPIC_AUTH_TOKEN=            # compatibility alias when LLM_MODEL=anthropic/...
# LLM_OPENAI_API_MODE=responses    # responses | chat_completions; only for openai/...
# LLM_MAX_TOKENS=8192
# LLM_THINKING_BUDGET=2048    # 0 disables extended thinking
# LLM_AUTO_COMPACT_ENABLED=true
# LLM_CONTEXT_WINDOW=20000
# LLM_AUTO_COMPACT_TRIGGER_RATIO=0.80
# LLM_AUTO_COMPACT_TARGET_RATIO=0.50
# MAX_STEP=10

# Execution environment: local | docker | opensandbox
# RUNTIME=local
# DOCKER_IMAGE=tinyhands-sandbox:latest
# OPENSANDBOX_SERVER_URL=http://localhost:8080
# OPENSANDBOX_API_KEY=
# OPENSANDBOX_IMAGE=opensandbox/code-interpreter:v1.1.0
