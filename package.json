{
  "name": "tinyhands-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A complete agent runtime",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "node scripts/clean-build.mjs all",
    "prebuild": "npm run clean",
    "build": "tsc -b --pretty false",
    "serve": "npm run build && tsx apps/standalone/src/main.ts",
    "dev": "npm run build && tsx apps/standalone/src/main.ts",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json --noEmit --pretty false",
    "test": "npm run typecheck && vitest run",
    "verify:crash": "npm run build && tsx scripts/verify-crash-recovery.ts",
    "verify:provider": "npm run build && tsx scripts/verify-provider-smoke.ts",
    "verify:compact": "npm run build && tsx scripts/verify-auto-compact-smoke.ts"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
