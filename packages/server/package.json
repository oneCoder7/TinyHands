{
  "name": "@tinyhands/server",
  "version": "0.1.0",
  "description": "Embeddable Tinyhands host and framework-neutral HTTP handler",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    }
  },
  "scripts": {
    "clean": "node ../../scripts/clean-build.mjs server",
    "prebuild": "npm run clean",
    "build": "tsc -b",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@alibaba-group/opensandbox": "^0.1.9",
    "@alibaba-group/opensandbox-code-interpreter": "^0.1.3",
    "@anthropic-ai/sdk": "^0.109.1",
    "@tinyhands/protocol": "0.1.0",
    "dockerode": "^5.0.1",
    "openai": "^6.47.0",
    "zod": "^3.23.8"
  }
}
