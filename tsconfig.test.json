{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@tinyhands/protocol": ["packages/protocol/src/index.ts"],
      "@tinyhands/server": ["packages/server/src/index.ts"],
      "@tinyhands/server/*": ["packages/server/src/*.ts"],
      "@tinyhands/sdk": ["packages/sdk/src/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist/**", "node_modules"]
}
